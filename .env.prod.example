# ====================================
# Production Environment Configuration
# For deployment with external PostgreSQL and Nginx
# ====================================

# ============ DATABASE ============
# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:mypassword@192.168.1.100:5432/english_partner
DATABASE_URL=postgresql://postgres:your_db_password@your_server_ip:5432/english_partner

# ============ JWT Configuration ============
# Generate a secure random key:
# On Linux/Mac: openssl rand -hex 32
# On Windows PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
SECRET_KEY=your_super_secret_key_min_32_characters_long

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ AI Provider Configuration ============
# Choose provider: openai or anthropic
AI_PROVIDER=anthropic

# --- OpenAI Configuration ---
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic Configuration (if using anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============ Frontend Configuration ============
# URL for browser to access backend through nginx
# Use https with /english path (production deployment)
NEXT_PUBLIC_API_URL=https://yourdomain.com/english
